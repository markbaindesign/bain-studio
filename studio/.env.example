# Asana credentials — copy this file to .env and fill in your values
# Get your PAT at: https://app.asana.com/0/my-apps

ASANA_PAT=your_personal_access_token_here

# Your Asana workspace GID — found in the URL when viewing your workspace
ASANA_WORKSPACE_GID=your_workspace_gid

# GID of the Asana user that tasks will be assigned to (the "bot" user)
# Find it at: https://app.asana.com/api/1.0/users/me (with your PAT)
ASANA_BAINBOT_GID=your_asana_user_gid

# GID of the custom text field used to store local task IDs (e.g. MCF-001)
# Create a text custom field in your workspace, then find its GID via the API
ASANA_LOCAL_ID_FIELD_GID=your_custom_field_gid

# Colon-separated paths to scan for CLAUDE.md files
# Defaults to ~/dev if not set
STUDIO_SCAN_ROOTS=/path/to/your/projects:/another/path

# Name used in mirror headers and log output (e.g. your name or "Bot")
STUDIO_ASSIGNEE_NAME=Bot
